function switchMode(m) {
  currentMode = m;
  document.getElementById('mode-flow').classList.toggle('hidden', m !== 'flow');
  document.getElementById('mode-check').classList.toggle('hidden', m !== 'check');
  document.getElementById('mode-list').classList.toggle('hidden', m !== 'list');
