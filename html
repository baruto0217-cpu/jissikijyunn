        </div>
        <div class="disease-btn" onclick="selectDisease('trauma')" id="d-trauma">
          <span class="d-icon">🩹</span>
          <div><div class="d-label">外傷・熱傷</div><div class="d-sub">高エネルギー等</div></div>
        </div>
        <div class="disease-btn" onclick="selectDisease('ob')" id="d-ob">
          <span class="d-icon">🤰</span>
          <div><div class="d-label">妊産婦</div><div class="d-sub">異常分娩・出血</div></div>
        </div>
