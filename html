function scrollToGroup(id, tabEl) {
  // タブのアクティブ切り替え
  document.querySelectorAll('.cat-tab').forEach(t => {
    if(!t.classList.contains('has-check')) t.classList.remove('active');
    else t.classList.remove('active');
  });
  tabEl.classList.add('active');

  const target = document.getElementById(id);
  if (!target) return;
  const offset = target.getBoundingClientRect().top + window.scrollY - 120;
  window.scrollTo({ top: offset, behavior: 'smooth' });
}

function updateSummary() {
  const checked = document.querySelectorAll('.symptom-check.checked');
  const summaryEl = document.getElementById('selected-summary');
  const tagsArea = document.getElementById('selected-tags-area');
  const badge = document.getElementById('selected-count-badge');

  if (checked.length === 0) {
    summaryEl.style.display = 'none';
    // タブのhas-checkをリセット
    document.querySelectorAll('.cat-tab').forEach(t => t.classList.remove('has-check', 'active'));
    document.querySelector('.cat-tab[data-target="sg-vital"]').classList.add('active');
    return;
  }

  summaryEl.style.display = '';
  badge.textContent = checked.length + '件';

  // タグ再描画
  tagsArea.innerHTML = '';
  checked.forEach(el => {
    const tag = document.createElement('div');
    tag.className = 'sel-tag';
    tag.innerHTML = el.textContent + '<span class="sel-tag-x">×</span>';
    tag.onclick = () => {
      el.classList.remove('checked');
      updateSummary();
      updateTabHasCheck();
    };
    tagsArea.appendChild(tag);
  });

  updateTabHasCheck();
}

function updateTabHasCheck() {
  // 各タブのhas-checkを更新
  document.querySelectorAll('.cat-tab').forEach(tab => {
    const targetId = tab.dataset.target;
    const group = document.getElementById(targetId);
    if (!group) return;
    const hasChecked = group.querySelector('.symptom-check.checked');
    tab.classList.toggle('has-check', !!hasChecked);
  });
}

function toggleCheck(el) {
  el.classList.toggle('checked');
  updateSummary();
  updateTabHasCheck();
}

