    </div>
    <div class="header-badge">尾張圏</div>
  </div>
</header>

<main>


<!-- ====== MODE: FLOW ====== -->
<div id="mode-flow">

  <!-- 疾患選択 -->
  <div class="card">
    <div class="card-header">
      <span class="card-header-icon">①</span>
      <span class="card-header-title">疾患・病態を選択</span>
    </div>
    <div class="card-body">
      <div class="disease-grid" id="disease-grid">
