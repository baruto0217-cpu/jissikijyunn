  btnSet('p-measure-yes',  type==='measure'  && val === true);
  btnSet('p-measure-no',   type==='measure'  && val === false);

  if (type === 'body') {
    if (val) {
      // 各分類観察基準に該当 → 各分類対応医療機関リスト
      showFlowResult('psych-body');
    } else {
      // なし → B: 精神症状を伴う身体疾患・その他の確認へ
      sectionShow('p-symptom-section', true);
      sectionShow('p-danger-section', false);
      sectionShow('p-physical-section', false);
      sectionShow('p-measure-section', false);
    }
  }
  if (type === 'symptom') {
    if (val) {
      // 精神症状を伴う身体疾患・その他に該当 → 救急告示医療機関
      showFlowResult('psych-symptom');
    } else {
      // なし → C: 自傷・他害の恐れ確認へ
      sectionShow('p-danger-section', true);
      sectionShow('p-physical-section', false);
      sectionShow('p-measure-section', false);
    }
  }
  if (type === 'danger') {
    if (val) {
      // 自傷・他害あり → 精神保健福祉法に基づく通報
      showFlowResult('psych-danger');
    } else {
      // なし → D: 身体症状の有無確認へ
      sectionShow('p-physical-section', true);
      sectionShow('p-measure-section', false);
    }
  }
  if (type === 'physical') {
    if (val) {
      // 身体症状あり → リスト10（精神・身体合併症）
      showFlowResult('psych-body');
    } else {
      // なし → ①精神科かかりつけ・②当番病院・③その他精神科病院
      showFlowResult('psych-only');
    }
  }
  if (type === 'measure') {
    if (val) {
      // 措置要 → 措置入院
      showFlowResult('psych-measure');
    } else {
      // 否 → 精神科かかりつけ・当番病院・その他精神科
      showFlowResult('psych-only');
    }
  }
}

