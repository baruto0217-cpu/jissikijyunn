// ⑧ 精神疾患
function setPsych(type, val) {
  psychState[type] = val;
  btnSet('p-body-yes',     type==='body'     && val === true);
  btnSet('p-body-no',      type==='body'     && val === false);
  btnSet('p-symptom-yes',  type==='symptom'  && val === true);
