function selectList(num, tabEl) {
  // タブ切り替え
  document.querySelectorAll('.list-tab').forEach(t => t.classList.remove('active'));
  if (tabEl) tabEl.classList.add('active');

  const cfg = LIST_CONFIG[num];
  const hospitals = HOSPITALS.filter(cfg.filter);
  const areas = AREA_ORDER.filter(a => hospitals.some(h => h.area === a));

  let html = `<div class="card">`;
  html += `<div class="list-section-header">`;
  html += `<div class="list-section-title">医療機関リスト${num}：${cfg.title}</div>`;
  html += `<div class="list-section-sub">${cfg.sub}　全${hospitals.length}施設</div>`;
  html += `</div>`;
  if (cfg.note) {
    if (num === 2) {
      // 脳卒中リストは血栓回収・一次SCの説明を整形して表示
      const lines = cfg.note.split('\n');
      html += `<div class="list-note" style="padding:10px 12px;">`;
      lines.forEach(line => {
        const m = line.match(/^(【.+?】)(.+)$/);
        if (m) html += `<div style="margin-bottom:6px"><span style="font-weight:700;color:var(--navy)">${m[1]}</span>${m[2]}</div>`;
        else if (line) html += `<div style="margin-bottom:4px">${line}</div>`;
      });
      html += `</div>`;
    } else {
      html += `<div class="list-note">⚠️ ${cfg.note}</div>`;
    }
  }

  areas.forEach(area => {
    const areaH = hospitals.filter(h => h.area === area);
    html += `<div class="list-area-header">📍 ${area}<span class="list-area-count">${areaH.length}施設</span></div>`;
    areaH.forEach(h => {
      html += `<div class="list-hospital-item">`;
      html += `<div class="list-hospital-name">${h.name}</div>`;
      html += `<div class="list-hospital-loc">${h.loc}</div>`;
      // バッジ
      const badges = [];
      if (num === 2) {
        if (h.stroke_tpa && h.stroke_pct) {
          badges.push(`<span class="list-badge list-badge-tpa">血栓回収療法</span>`);
          badges.push(`<span class="list-badge list-badge-pct">一次脳卒中センター</span>`);
        } else if (h.stroke_tpa) {
          badges.push(`<span class="list-badge list-badge-tpa">血栓回収療法</span>`);
        } else if (h.stroke_pct) {
          badges.push(`<span class="list-badge list-badge-pct">一次脳卒中センター</span>`);
        }
      }
      if (num === 4) {
        if (h.burn && h.trauma) badges.push(`<span class="list-badge list-badge-burn">外傷・熱傷</span>`);
        else if (h.burn) badges.push(`<span class="list-badge list-badge-burn">熱傷</span>`);
        else badges.push(`<span class="list-badge" style="background:#EAFAF1;color:#1E8449">外傷のみ</span>`);
      }
      if (num === 5 && h.ob_center) badges.push(`<span class="list-badge list-badge-ob">${h.ob_center}</span>`);
      if (num === 6) {
        if (h.stroke_tpa) badges.push(`<span class="list-badge list-badge-tpa">血栓回収</span>`);
        if (h.mi) badges.push(`<span class="list-badge" style="background:#FEF9E7;color:#B7950B">心梗</span>`);
        if (h.trauma) badges.push(`<span class="list-badge" style="background:#EAFAF1;color:#1E8449">外傷</span>`);
        if (h.burn) badges.push(`<span class="list-badge list-badge-burn">熱傷</span>`);
      }
      if (num === 9 && h.tele) badges.push(`<span class="list-badge list-badge-tele">Teletriage</span>`);
      if (num === 11 && h.kakuho_psych) badges.push(`<span class="list-badge list-badge-psych" style="background:#F4F6F7;color:#616A6B">精神疾患のみ</span>`);
      if (num === 11 && h.kakuho) badges.push(`<span class="list-badge" style="background:#1A2535;color:#fff">精神疾患以外</span>`);
      if (badges.length > 0) html += `<div class="list-hospital-tags">${badges.join('')}</div>`;
      html += `</div>`;
    });
  });

  html += `</div>`;
  const contentEl = document.getElementById('list-content');
  contentEl.innerHTML = html;
  contentEl.classList.add('fade-in');
}
