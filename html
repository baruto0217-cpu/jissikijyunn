function setVital(type, val) {
  vitalState[type] = val;
  btnSet('v-cpa-yes', type==='cpa' && val);
  btnSet('v-cpa-no',  type==='cpa' && !val);
  btnSet('v-shock-yes', type==='shock' && val);
  btnSet('v-shock-no',  type==='shock' && !val);

  if (type === 'cpa') {
    if (val) { showFlowResult('list1'); }
    else { sectionShow('v-detail-section', true); }
  }
  if (type === 'shock') {
    if (val) {
      // 手指切断の場合のみ生理学的評価あり → リスト4（外傷）
      // それ以外 → リスト1（CPA等）
      if (selectedDisease === 'digit') {
        showFlowResult('trauma');
      } else {
        showFlowResult('list1');
      }
    } else {
      showDiseaseFlow(selectedDisease);
    }
  }
}

// ① 脳卒中
function setStroke(type, val) {
  strokeState[type] = val;
  btnSet('s-cpss-yes',  type==='cpss'  && val === true);
  btnSet('s-cpss-no',   type==='cpss'  && val === false);
  btnSet('s-elvo-yes',  type==='elvo'  && val === true);
  btnSet('s-elvo-no',   type==='elvo'  && val === false);
  btnSet('s-other-yes', type==='other' && val === true);
  btnSet('s-other-no',  type==='other' && val === false);

  if (type === 'cpss') {
    // CPSS あり・なし どちらもELVO確認へ
    sectionShow('s-elvo-section', true);
    sectionShow('s-other-section', false);
  }
  if (type === 'elvo') {
    if (val) {
      // ELVOあり → CPSS有無に関わらず血栓回収
      showFlowResult('stroke-elvo');
    } else {
      // ELVOなし → CPSSありなら一次SC、CPSSなしならその他症状へ
      if (strokeState.cpss === true) {
        showFlowResult('stroke-cpss');
      } else {
        sectionShow('s-other-section', true);
      }
    }
  }
  if (type === 'other') {
    if (val) {
      showFlowResult('stroke-other');
    } else {
      showNoMatch('🧠 脳卒中特有症状のいずれにも該当しませんでした。脳卒中疑いなし。');
    }
  }
}

